# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Core
# NOBRAINR_DATABASE_URL=postgresql://nobrainr:nobrainr@localhost:5432/nobrainr
# NOBRAINR_OLLAMA_URL=http://localhost:11434
# NOBRAINR_HOST=0.0.0.0
# NOBRAINR_PORT=8420

# Machine identifier — tags memories created by scheduler/crawler jobs
# Set this to identify which machine produced a memory (e.g., "workstation", "server")
# NOBRAINR_SOURCE_MACHINE=my-server

# Extraction (knowledge graph)
NOBRAINR_EXTRACTION_ENABLED=true
NOBRAINR_EXTRACTION_MODEL=gemma3:12b

# Chat (RAG chatbot)
# NOBRAINR_CHAT_ENABLED=true
# NOBRAINR_CHAT_MODEL=gemma3:12b
# NOBRAINR_CHAT_MAX_CONTEXT_MEMORIES=15
# NOBRAINR_CHAT_MAX_MESSAGE_LENGTH=2000
# NOBRAINR_CHAT_MAX_HISTORY_LENGTH=20

# Crawl4AI (web crawling)
# NOBRAINR_CRAWL4AI_URL=http://crawl4ai:11235
# NOBRAINR_CRAWL4AI_API_TOKEN=

# Scheduler — LLM concurrency and model
# NOBRAINR_SCHEDULER_ENABLED=true
# NOBRAINR_SCHEDULER_LLM_CONCURRENCY=3
# NOBRAINR_SCHEDULER_INTER_REQUEST_DELAY=1.0
# NOBRAINR_SCHEDULER_LLM_MODEL=gemma3:12b

# Scheduler job intervals (hours)
# NOBRAINR_MAINTENANCE_INTERVAL_HOURS=6.0
# NOBRAINR_FEEDBACK_INTERVAL_HOURS=12.0
# NOBRAINR_SUMMARIZE_INTERVAL_HOURS=1.0
# NOBRAINR_CONSOLIDATION_INTERVAL_HOURS=2.0
# NOBRAINR_SYNTHESIS_INTERVAL_HOURS=4.0
# NOBRAINR_ENTITY_ENRICHMENT_INTERVAL_HOURS=2.0
# NOBRAINR_ENTITY_MERGING_INTERVAL_HOURS=2.0
# NOBRAINR_INSIGHT_EXTRACTION_INTERVAL_HOURS=1.0
# NOBRAINR_CHATGPT_DISTILL_INTERVAL_HOURS=0.1
# NOBRAINR_CHATGPT_DISTILL_MODEL=gemma3:12b
# NOBRAINR_CONTRADICTION_INTERVAL_HOURS=4.0
# NOBRAINR_CROSS_MACHINE_INTERVAL_HOURS=6.0
# NOBRAINR_QUALITY_INTERVAL_HOURS=4.0
# NOBRAINR_DECAY_INTERVAL_HOURS=24.0
# NOBRAINR_QUALITY_SCORING_INTERVAL_HOURS=0.5

# Scheduler batch sizes
# NOBRAINR_SUMMARIZE_BATCH_SIZE=20
# NOBRAINR_CONSOLIDATION_BATCH_SIZE=10
# NOBRAINR_SYNTHESIS_BATCH_SIZE=5
# NOBRAINR_ENTITY_ENRICHMENT_BATCH_SIZE=20
# NOBRAINR_ENTITY_MERGING_BATCH_SIZE=15
# NOBRAINR_INSIGHT_EXTRACTION_BATCH_SIZE=30
# NOBRAINR_CHATGPT_DISTILL_BATCH_SIZE=20
# NOBRAINR_CONTRADICTION_BATCH_SIZE=10
# NOBRAINR_CROSS_MACHINE_BATCH_SIZE=5
# NOBRAINR_QUALITY_BATCH_SIZE=20
# NOBRAINR_QUALITY_SCORING_BATCH_SIZE=30
# NOBRAINR_DECAY_BATCH_SIZE=50

# Web intelligence — autonomous crawling
# NOBRAINR_KNOWLEDGE_CRAWL_ENABLED=true
# NOBRAINR_KNOWLEDGE_CRAWL_INTERVAL_HOURS=6.0
# NOBRAINR_KNOWLEDGE_CRAWL_BATCH_SIZE=3
# NOBRAINR_KNOWLEDGE_CRAWL_DELAY=10.0

# Link discovery
# NOBRAINR_LINK_DISCOVERY_ENABLED=true
# NOBRAINR_LINK_DISCOVERY_MAX_PER_PAGE=5
# NOBRAINR_LINK_DISCOVERY_MIN_SCORE=0.4

# Entity web research
# NOBRAINR_ENTITY_RESEARCH_ENABLED=true
# NOBRAINR_ENTITY_RESEARCH_INTERVAL_HOURS=12.0
# NOBRAINR_ENTITY_RESEARCH_BATCH_SIZE=3
# NOBRAINR_ENTITY_RESEARCH_MIN_MENTIONS=5
# NOBRAINR_ENTITY_RESEARCH_COOLDOWN_DAYS=14

# Freshness re-crawl
# NOBRAINR_FRESHNESS_ENABLED=true
# NOBRAINR_FRESHNESS_INTERVAL_HOURS=24.0
# NOBRAINR_FRESHNESS_BATCH_SIZE=3
# NOBRAINR_FRESHNESS_MAX_AGE_DAYS=30

# Interest-based expansion
# NOBRAINR_INTEREST_TRACKING_ENABLED=true
# NOBRAINR_INTEREST_EXPANSION_INTERVAL_HOURS=24.0
# NOBRAINR_INTEREST_EXPANSION_BATCH_SIZE=3
# NOBRAINR_INTEREST_SIGNAL_DECAY_DAYS=30

# Search defaults
# NOBRAINR_DEFAULT_SEARCH_LIMIT=10
# NOBRAINR_DEFAULT_SIMILARITY_THRESHOLD=0.3

# Security
# NOBRAINR_CORS_ORIGINS=["*"]
# NOBRAINR_MAX_CONTENT_LENGTH=50000
