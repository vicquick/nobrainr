# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# Extraction (knowledge graph) — requires an Ollama model that supports structured output
# Set to false to disable automatic entity extraction
NOBRAINR_EXTRACTION_ENABLED=true
NOBRAINR_EXTRACTION_MODEL=qwen3.5:9b

# These are set automatically in docker-compose, but needed for local dev:
# NOBRAINR_DATABASE_URL=postgresql://nobrainr:nobrainr@localhost:5433/nobrainr
# NOBRAINR_OLLAMA_URL=http://localhost:11434
# NOBRAINR_HOST=0.0.0.0
# NOBRAINR_PORT=8420

# Scheduler intervals (hours) — tune for your hardware
# NOBRAINR_SUMMARIZE_INTERVAL_HOURS=1.0
# NOBRAINR_CONSOLIDATION_INTERVAL_HOURS=2.0
# NOBRAINR_SYNTHESIS_INTERVAL_HOURS=4.0
# NOBRAINR_CHATGPT_DISTILL_INTERVAL_HOURS=0.1
# NOBRAINR_CHATGPT_DISTILL_MODEL=qwen3.5:9b
# NOBRAINR_CONTRADICTION_INTERVAL_HOURS=4.0
# NOBRAINR_CROSS_MACHINE_INTERVAL_HOURS=6.0
# NOBRAINR_QUALITY_INTERVAL_HOURS=4.0
# NOBRAINR_DECAY_INTERVAL_HOURS=24.0

# Machine identifier for memories created by scheduler jobs
# Defaults to system hostname if not set
# NOBRAINR_SOURCE_MACHINE=my-server
